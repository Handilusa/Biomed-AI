# BioMed AI - Environment Configuration
# Copy this file to .env and adjust values as needed.
# cp .env.example .env

# Server
PORT=3000
HOST=localhost

# Models (paths relative to project root)
MODEL_DIR=./models
LLM_MODEL_FILE=medpsy-4b-q4_k_m-imat.gguf
EMBED_MODEL_FILE=nomic-embed-text-v1.5.Q4_K_M.gguf

# RAG
RAG_CHUNK_SIZE=512
RAG_CHUNK_OVERLAP=50
RAG_TOP_K=3

# Logging
LOG_DIR=./logs
LOG_LEVEL=info

# UI Language (en | es)
UI_LANG=en
