# Edge MedTech Copilot — Environment Configuration
# Copy this file to .env and adjust values as needed.

# Server
PORT=3000
HOST=localhost

# Models (paths relative to project root, or absolute)
MODEL_DIR=./models
LLM_MODEL_FILE=MedPsy-4B-Q4_K_M.gguf
EMBED_MODEL_FILE=all-MiniLM-L6-v2.Q8_0.gguf

# RAG
RAG_DB_PATH=./rag_index.sqlite
RAG_CHUNK_SIZE=512
RAG_CHUNK_OVERLAP=50
RAG_TOP_K=5

# Logging
LOG_DIR=./logs
LOG_LEVEL=info

# UI Language (en | es)
UI_LANG=en
